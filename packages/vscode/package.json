{
  "publisher": "NailyZero",
  "name": "vscode-naily-ets",
  "displayName": "Naily's ArkTS Support",
  "version": "1.2.13",
  "private": true,
  "description": "自用ArkTS扩展,支持代码跳转,欢迎PR! Naily's ArkTS Support.",
  "author": "Naily Zero <zero@naily.cc>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Groupguanfang/arkTS",
    "directory": "packages/vscode"
  },
  "bugs": {
    "url": "https://github.com/Groupguanfang/arkTS/issues",
    "email": "zero@naily.cc"
  },
  "keywords": [
    "ArkTS",
    "ets",
    "huawei"
  ],
  "categories": [
    "Programming Languages",
    "Linters",
    "Snippets",
    "Formatters",
    "Themes"
  ],
  "main": "./dist/client.js",
  "icon": "assets/icon.png",
  "engines": {
    "vscode": "^1.61.0"
  },
  "galleryBanner": {
    "theme": "dark",
    "color": "#37337a"
  },
  "activationEvents": [
    "workspaceContains:**/*.ets",
    "workspaceContains:**/build-profile.json5",
    "workspaceContains:**/oh-package.json5"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ets-resource-explorer",
          "title": "%resourceExplorer%",
          "icon": "./assets/resource-explorer.svg"
        }
      ],
      "panel": [
        {
          "id": "ets-hdc-manager",
          "title": "%hdcManager.title%",
          "icon": "$(device-desktop)"
        }
      ]
    },
    "breakpoints": [
      {
        "language": "ets"
      }
    ],
    "taskDefinitions": [
      {
        "type": "hvigor-debug-deploy",
        "properties": {
          "projectRoot": {
            "type": "string",
            "description": "Hvigor 项目根目录。",
            "default": "${workspaceFolder}"
          },
          "moduleName": {
            "type": "string",
            "description": "模块名称。",
            "default": "entry"
          },
          "productName": {
            "type": "string",
            "description": "产品名称。",
            "default": "default"
          },
          "requiredDeviceType": {
            "type": "string",
            "description": "调试设备类型。默认自动使用hdc shell param get \"const.product.devicetype\" 获取。"
          },
          "analyze": {
            "type": "string",
            "description": "构建分析模式",
            "default": "normal"
          },
          "parallel": {
            "type": "boolean",
            "description": "是否开启并行构建",
            "default": true
          },
          "incremental": {
            "type": "boolean",
            "description": "是否开启增量构建",
            "default": true
          },
          "daemon": {
            "type": "boolean",
            "default": true
          },
          "args": {
            "types": "array",
            "default": [],
            "description": "额外参数",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "projectRoot"
        ]
      }
    ],
    "views": {
      "ets-resource-explorer": [
        {
          "id": "ets.resourceExplorer",
          "name": "%resourceExplorer%",
          "icon": "$(folder)",
          "contextualTitle": "%resourceExplorer%"
        }
      ],
      "ets-hdc-manager": [
        {
          "type": "webview",
          "id": "ets.hdcManager",
          "name": "%hdcManager.title%",
          "icon": "$(device-desktop)",
          "contextualTitle": "%hdcManager.title%"
        }
      ]
    },
    "debuggers": [
      {
        "type": "ets",
        "label": "ArkTS Debugger",
        "languages": [
          "ets"
        ],
        "configurationAttributes": {
          "launch": {
            "type": "object",
            "properties": {
              "abilityName": {
                "type": "string",
                "description": "Ability 名称，默认 EntryAbility",
                "default": "EntryAbility"
              },
              "controlPort": {
                "type": "number",
                "description": "控制端口，默认 9230",
                "default": 9230
              },
              "devtoolsPort": {
                "type": "number",
                "description": "DevTools 端口，默认 9229",
                "default": 9229
              },
              "projectRoot": {
                "type": "string",
                "description": "Hvigor 项目根目录",
                "default": "${workspaceFolder}"
              },
              "moduleName": {
                "type": "string",
                "description": "模块名称，必填"
              },
              "sourceMapFilePath": {
                "type": "string",
                "description": "Source Map 文件路径。",
                "default": "build/default/cache/default/default@CompileArkTS/esmodule/debug/sourceMaps.json"
              }
            },
            "required": [
              "projectRoot",
              "moduleName"
            ],
            "additionalProperties": true
          }
        }
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "ets.resourceExplorer.refresh",
          "group": "navigation",
          "when": "view == ets.resourceExplorer"
        }
      ],
      "view/item/context": [
        {
          "command": "ets.resourceExplorer.openFile",
          "group": "inline",
          "when": "view == ets.resourceExplorer && viewItem == ElementJsonFile"
        },
        {
          "command": "ets.resourceExplorer.openFile",
          "group": "inline",
          "when": "view == ets.resourceExplorer && (viewItem == ElementJsonFile || viewItem == MediaFile)"
        },
        {
          "command": "ets.resourceExplorer.openResourceQualifierEditor",
          "group": "inline",
          "when": "view == ets.resourceExplorer && viewItem == Resource"
        }
      ],
      "editor/title": [
        {
          "command": "ets.restartServer"
        }
      ],
      "editor/title/run": [
        {
          "command": "ets.openHdcManager",
          "group": "navigation"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "explorer",
        "contents": "%viewWelcome.createProject%"
      }
    ],
    "jsonValidation": [
      {
        "fileMatch": "module.json5",
        "url": "./schemas/module.schema.json"
      },
      {
        "fileMatch": "oh-package.json5",
        "url": "./schemas/oh-package.schema.json"
      },
      {
        "fileMatch": "build-profile.json5",
        "url": "./schemas/build-profile.schema.json"
      },
      {
        "fileMatch": "main_pages.json",
        "url": "./schemas/main_pages.schema.json"
      },
      {
        "fileMatch": [
          "**/element/*.json"
        ],
        "url": "./schemas/element.schema.json"
      },
      {
        "fileMatch": "code-linter.json5",
        "url": "./schemas/code-linter.schema.json"
      },
      {
        "fileMatch": "hvigor-config.json5",
        "url": "./schemas/hvigor-config.schema.json"
      },
      {
        "fileMatch": "mock-config.json5",
        "url": "./schemas/mock-config.schema.json"
      },
      {
        "fileMatch": [
          "tsconfig.json",
          "tsconfig.*.json",
          "tsconfig-*.json",
          "jsconfig.json",
          "jsconfig.*.json",
          "jsconfig-*.json"
        ],
        "url": "./schemas/ets-tsconfig.schema.json"
      },
      {
        "fileMatch": "app.json5",
        "url": "./schemas/app.schema.json"
      }
    ],
    "iconThemes": [
      {
        "id": "arkts-icons",
        "label": "ArkTS Icons",
        "path": "./icons/arkts-icon-theme.json"
      }
    ],
    "languages": [
      {
        "id": "ets",
        "extensions": [
          ".ets",
          ".d.ets"
        ],
        "aliases": [
          "ArkTS",
          "ets"
        ],
        "configuration": "./language/language-configuration.json",
        "bases": [
          "typescript"
        ]
      }
    ],
    "snippets": [
      {
        "language": "ets",
        "path": "./snippets/ets.code-snippets"
      }
    ],
    "grammars": [
      {
        "language": "ets",
        "scopeName": "source.ets",
        "path": "./syntaxes/ets.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "ets.restartServer",
        "title": "%command.restartServer%",
        "category": "ETS"
      },
      {
        "command": "ets.installSDK",
        "title": "%command.installSDK%",
        "category": "ETS"
      },
      {
        "command": "ets.createProject",
        "title": "%command.createProject%",
        "category": "ETS"
      },
      {
        "command": "ets.resourceExplorer.refresh",
        "title": "%command.resourceExplorer.refresh%",
        "icon": "$(refresh)",
        "category": "ETS"
      },
      {
        "command": "ets.resourceExplorer.openFile",
        "title": "%command.resourceExplorer.openFile%",
        "icon": "$(link-external)",
        "category": "ETS"
      },
      {
        "command": "ets.resourceExplorer.openResourceQualifierEditor",
        "title": "%command.resourceExplorer.openResourceQualifierEditor%",
        "icon": "$(plus)",
        "category": "ETS"
      },
      {
        "command": "ets.openHdcManager",
        "title": "%command.openHdcManager%",
        "icon": "$(device-desktop)",
        "category": "ETS"
      }
    ],
    "configuration": {
      "title": "%extension.name%",
      "type": "object",
      "properties": {
        "ets.sdkPath": {
          "type": "string",
          "description": "%configuration.ets.sdkPath.description%",
          "default": ""
        },
        "ets.baseSdkPath": {
          "type": "string",
          "markdownDescription": "%configuration.ets.baseSdkPath.description%",
          "default": "${os.homedir}/OpenHarmony"
        },
        "ets.hmsPath": {
          "type": "string",
          "description": "%configuration.ets.hmsPath.description%",
          "default": ""
        },
        "ets.lspDebugMode": {
          "type": "boolean",
          "description": "%configuration.ets.lspDebugMode.description%",
          "default": false
        },
        "ets.ignoreWorkspaceLocalPropertiesFile": {
          "type": "boolean",
          "markdownDescription": "%configuration.ets.ignoreWorkspaceLocalPropertiesFile.description%",
          "default": false
        },
        "ets.linterVersion": {
          "type": "string",
          "description": "The version of the ArkTS linter to use. Set to 'off' to disable the linter.",
          "enum": [
            "1.0",
            "1.1",
            "off"
          ],
          "default": "1.1"
        },
        "ets.resourceReferenceDiagnostic": {
          "type": "string",
          "description": "未匹配到的 $r() 资源引用的诊断级别",
          "enum": [
            "error",
            "warning",
            "none"
          ],
          "enumDescriptions": [
            "显示为错误",
            "显示为警告",
            "不显示任何诊断"
          ],
          "default": "error"
        },
        "ets.localImagePath": {
          "type": "string",
          "description": "%configuration.ets.localImagePath.description%",
          "markdownDescription": "%configuration.ets.localImagePath.description%"
        }
      }
    },
    "typescriptServerPlugins": [
      {
        "name": "ets-typescript-plugin",
        "enableForWorkspaceTypeScriptVersions": true
      }
    ],
    "walkthroughs": [
      {
        "id": "ArkTS-Walkthrough",
        "title": "%walkthroughs.ArkTS-Walkthrough.title%",
        "description": "%walkthroughs.ArkTS-Walkthrough.description%",
        "steps": [
          {
            "id": "ArkTS-Walkthrough-InstallSDK",
            "title": "%walkthroughs.ArkTS-Walkthrough.steps.installOpenHarmonySDK%",
            "description": "%walkthroughs.ArkTS-Walkthrough.steps.installOpenHarmonySDK.description%",
            "media": {
              "markdown": "%walkthroughs.ArkTS-Walkthrough.steps.installOpenHarmonySDK.media.markdown%"
            }
          }
        ]
      }
    ]
  },
  "scripts": {
    "build": "tsdown",
    "watch": "cross-env NODE_ENV=development tsdown",
    "pack": "tsx scripts/pre-process.ts && pnpm run build && vsce package",
    "postpack": "tsx scripts/clean-process.ts",
    "update": "vscode-ext-gen --output src/generated/meta.ts --locale zh-cn && vscode-ext-gen --output src/generated/meta.ts --locale zh-cn --readme ../../README.md && vscode-ext-gen --output src/generated/meta.ts --locale --readme ../../README-en.md",
    "ovsx": "ovsx",
    "vsce": "vsce"
  },
  "dependencies": {
    "@napi-rs/wasm-runtime": "^1.0.7"
  },
  "devDependencies": {
    "@types/vscode": "^1.22.0"
  }
}
