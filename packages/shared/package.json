{
  "name": "@arkts/shared",
  "version": "1.0.7",
  "description": "ArkTS common utilities package.",
  "author": "Naily Zero <zero@naily.cc>",
  "license": "MIT",
  "homepage": "https://github.com/Groupguanfang/arkTS/tree/main/packages/language-server",
  "repository": {
    "type": "git",
    "url": "https://github.com/Groupguanfang/arkTS",
    "directory": "packages/language-server"
  },
  "bugs": {
    "url": "https://github.com/Groupguanfang/arkTS/issues",
    "email": "zero@naily.cc"
  },
  "keywords": [
    "arkts",
    "shared",
    "typescript"
  ],
  "exports": {
    ".": {
      "types": {
        "import": "./out/index.d.mts",
        "require": "./out/index.d.ts"
      },
      "import": "./out/index.mjs",
      "require": "./out/index.js"
    },
    "./vscode": {
      "types": {
        "import": "./out/vscode.d.mts",
        "require": "./out/vscode.d.ts"
      },
      "import": "./out/vscode.mjs",
      "require": "./out/vscode.js"
    },
    "./out/*": "./out/*"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./out/index.js",
  "module": "./out/index.mjs",
  "types": "./out/index.d.ts",
  "scripts": {
    "build": "tsdown --tsconfig ./tsconfig.build.json",
    "prepublishOnly": "tsdown --tsconfig ./tsconfig.build.json",
    "release": "pnpm publish",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "consola": "^3.4.2",
    "kleur": "^4.1.5",
    "ohos-typescript": "workspace:*",
    "vscode-languageserver-textdocument": "^1.0.12",
    "vscode-uri": "^3.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.18.12",
    "@types/vscode": "^1.104.0"
  }
}
