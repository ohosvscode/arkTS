{
  "name": "@arkts/language-server",
  "version": "1.3.9",
  "description": "ArkTS Language Server.",
  "author": "Naily Zero <zero@naily.cc>",
  "license": "MIT",
  "homepage": "https://github.com/ohosvscode/arkTS/tree/next/packages/language-server",
  "repository": {
    "type": "git",
    "url": "https://github.com/ohosvscode/arkTS",
    "directory": "packages/language-server"
  },
  "bugs": {
    "url": "https://github.com/ohosvscode/arkTS/issues",
    "email": "zero@naily.cc"
  },
  "keywords": [
    "language-server",
    "language-server-protocol",
    "harmonyos",
    "arkts",
    "ets"
  ],
  "exports": {
    ".": {
      "types": {
        "import": "./out/index.d.mts",
        "require": "./out/index.d.ts",
        "default": "./out/index.d.ts"
      },
      "import": "./out/index.mjs",
      "default": "./out/index.js"
    },
    "./dist/*": "./dist/*"
  },
  "main": "./out/index.js",
  "module": "./out/index.mjs",
  "types": "./out/index.d.ts",
  "bin": {
    "ets-language-server": "./bin/ets-language-server.js"
  },
  "files": [
    "bin",
    "out"
  ],
  "engines": {
    "node": ">=16.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack --tsconfig ./tsconfig.build.json",
    "prepublishOnly": "vp pack --tsconfig ./tsconfig.build.json",
    "release": "pnpm publish"
  },
  "dependencies": {
    "@arkts/language-plugin": "workspace:*",
    "@arkts/language-service": "workspace:*",
    "@arkts/project-detector": "catalog:prod",
    "@arkts/shared": "workspace:*",
    "@ohos-rs/oxk": "catalog:prod",
    "@volar/language-server": "catalog:prod",
    "@vstils/core": "catalog:prod",
    "@vstils/fs": "catalog:prod",
    "volar-service-typescript": "catalog:prod"
  },
  "devDependencies": {
    "ohos-typescript": "workspace:*"
  }
}
