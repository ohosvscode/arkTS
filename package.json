{
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.17.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/ohosvscode/arkTS.git"
  },
  "scripts": {
    "build": "pnpm -F vscode-naily-ets build",
    "watch": "pnpm -F vscode-naily-ets watch",
    "pack": "pnpm -F vscode-naily-ets pack",
    "generate": "pnpm -F vscode-naily-ets update",
    "release": "pnpm -F \"{packages/*}\" build && tsx ./scripts/publish.ts",
    "test": "vitest --coverage --ui",
    "test:compatible": "vitest run e2e/compatible.test.ts",
    "lint": "eslint --fix && oxlint && tsc --noEmit && vitest --coverage",
    "prepare": "pnpm -F \"{packages/*}\" build"
  },
