{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "jsx": "preserve",
    "jsxFactory": "h",
    "jsxFragmentFactory": "Fragment",
    "jsxImportSource": "vue",
    "lib": ["ESNext"],
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "strict": true,
    "declaration": true,
    "skipDefaultLibCheck": true,
    "skipLibCheck": true
  }
}
