{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.cache/tsconfig.server.tsbuildinfo",
    "types": ["vite-plus/client", "node"],
    "isolatedDeclarations": true
  },
  "include": [
    "packages/arkts-language-server/src",
    "extensions/arkts-vscode-language-features/src/node.ts",
    "extensions/arkts-vscode-language-features/src/node/**/*",
    "extensions/arkts-vscode-language-features/src/common/**/*",
    "packages/arkts-vfs/src",
    "packages/arkts-typescript-plugin/src",
    "extensions/arkts-vscode-emulator-manager/src/extension.ts"
  ]
}
