{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Language Features",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceRoot}/arkts-vscode-language-features",
        "--folder-uri=${workspaceRoot}/arkts-vscode-language-features/e2e/22"
      ],
      "outFiles": [
        "${workspaceRoot}/arkts-vscode-language-features/dist/*.js"
      ],
      "preLaunchTask": {
        "type": "npm",
        "script": "watch"
      }
    },
    {
      "name": "Attach Language Server",
      "type": "node",
      "request": "attach",
      "port": 6009,
      "restart": true,
      "outFiles": [
        "${workspaceRoot}/arkts-vscode-language-features/dist/*.js"
      ]
    }
  ]
}
