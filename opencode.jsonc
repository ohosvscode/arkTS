{
  "$schema": "https://opencode.ai/config.json",
  "lsp": {
    "ets-lsp": {
      "command": [
        "node",
        "packages/language-server/out/index.js",
        "--stdio"
      ],
      "extensions": [".ets", ".ts"],
      "initialization": {
        "ets": {
          "sdkPath": "/Applications/DevEco-Studio.app/Contents/sdk/default/openharmon"
        }
      }
    }
  }
}
